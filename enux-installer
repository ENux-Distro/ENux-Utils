#!/bin/bash
# ENux Installer - Simple TUI Installer for ENux GNU/Linux

set -e

MOUNTPOINT=/mnt/ENux
LOGFILE=/tmp/enux-install.log
BEDROCK_URL="https://github.com/bedrocklinux/bedrocklinux-userland/releases/download/0.7.31/bedrock-linux-0.7.31-x86_64.sh"

log() { echo "[$(date '+%H:%M:%S')] $*" >> $LOGFILE; }
msg() { dialog --backtitle "ENux Installer" --msgbox "\n$*" 10 60; }
bail() { msg "ERROR: $*\n\nCheck $LOGFILE for details."; exit 1; }

if [ "$EUID" -ne 0 ]; then
    echo "Please run as root."
    exit 1
fi

> $LOGFILE
clear

# ── Welcome ────────────────────────────────────
dialog --backtitle "ENux Installer" \
       --title "Welcome" \
       --msgbox "\n  ENux GNU/Linux Installer\n\n  You will be dropped into cfdisk to partition your disk.\n  After partitioning, the installer will ask which\n  partitions to use, then install ENux automatically.\n\n  Make sure you have an internet connection for Bedrock." \
       14 60

# ── Disk select ────────────────────────────────
DISKS=()
while IFS= read -r line; do
    DEV=$(echo "$line" | awk '{print $1}')
    SIZE=$(echo "$line" | awk '{print $2}')
    MODEL=$(echo "$line" | awk '{$1=$2=""; print $0}' | xargs)
    DISKS+=("/dev/$DEV" "$SIZE $MODEL")
done < <(lsblk -d -o NAME,SIZE,MODEL --noheadings | grep -v loop)

DISK=$(dialog --backtitle "ENux Installer" \
              --title "Select Disk" \
              --menu "\nSelect the disk to partition:" \
              15 65 6 \
              "${DISKS[@]}" \
              3>&1 1>&2 2>&3) || bail "No disk selected."

# ── cfdisk loop ────────────────────────────────
while true; do
    clear
    cfdisk $DISK
    dialog --backtitle "ENux Installer" \
           --title "Partitioning" \
           --yesno "\nDo you want to return to cfdisk?" \
           8 55 || break
done

# ── Partition selection ────────────────────────
PARTS=()
while IFS= read -r line; do
    PNAME=$(echo "$line" | awk '{print $1}')
    PSIZE=$(echo "$line" | awk '{print $2}')
    PFS=$(echo "$line"   | awk '{print $3}')
    PARTS+=("/dev/$PNAME" "$PSIZE ${PFS:-unknown}")
done < <(lsblk $DISK -o NAME,SIZE,FSTYPE --noheadings | grep -v "^$(basename $DISK) ")

ROOT_PART=$(dialog --backtitle "ENux Installer" \
                   --title "Root Partition" \
                   --menu "\nSelect the ROOT (/) partition:" \
                   15 60 6 "${PARTS[@]}" \
                   3>&1 1>&2 2>&3) || bail "No root partition selected."

EFI_PART="none"
if [ -d /sys/firmware/efi ]; then
    EFI_PART=$(dialog --backtitle "ENux Installer" \
                      --title "EFI Partition" \
                      --menu "\nSelect the EFI partition:" \
                      15 60 6 "${PARTS[@]}" \
                      3>&1 1>&2 2>&3) || bail "No EFI partition selected."
fi

SWAP_PART=$(dialog --backtitle "ENux Installer" \
                   --title "Swap Partition (Optional)" \
                   --menu "\nSelect the SWAP partition:" \
                   15 60 7 \
                   "none" "Skip swap" \
                   "${PARTS[@]}" \
                   3>&1 1>&2 2>&3) || SWAP_PART="none"

# ── User setup ─────────────────────────────────
USERNAME=$(dialog --backtitle "ENux Installer" \
                  --title "Create User" \
                  --inputbox "\nEnter your username:" \
                  8 50 \
                  3>&1 1>&2 2>&3) || bail "No username entered."

PASSWORD=$(dialog --backtitle "ENux Installer" \
                  --title "Create User" \
                  --passwordbox "\nEnter password for $USERNAME:" \
                  8 50 \
                  3>&1 1>&2 2>&3) || bail "No password entered."

ROOT_PASSWORD=$(dialog --backtitle "ENux Installer" \
                       --title "Root Password" \
                       --passwordbox "\nEnter root password:" \
                       8 50 \
                       3>&1 1>&2 2>&3) || bail "No root password entered."

HOSTNAME=$(dialog --backtitle "ENux Installer" \
                  --title "Hostname" \
                  --inputbox "\nEnter a hostname for your system:" \
                  8 50 "ENux" \
                  3>&1 1>&2 2>&3) || bail "No hostname entered."

# ── Confirm ────────────────────────────────────
EFI_LINE=""
[ "$EFI_PART" != "none" ] && EFI_LINE="\n  EFI:       $EFI_PART"

dialog --backtitle "ENux Installer" \
       --title "Confirm" \
       --yesno "\nReady to install with:\n\n  Disk:      $DISK\n  Root:      $ROOT_PART$EFI_LINE\n  Swap:      $SWAP_PART\n  User:      $USERNAME\n  Hostname:  $HOSTNAME\n\nProceed?" \
       16 55 || bail "Installation cancelled by user."

# ══════════════════════════════════════════════
# INSTALLATION
# ══════════════════════════════════════════════

# ── Format & mount ─────────────────────────────
dialog --backtitle "ENux Installer" --title "Installing ENux..." \
       --infobox "\n[1/7] Formatting and mounting partitions..." 5 55

log "Formatting partitions..."
mkfs.ext4 -F $ROOT_PART >> $LOGFILE 2>&1 || bail "Failed to format $ROOT_PART"
if [ "$SWAP_PART" != "none" ]; then
    mkswap $SWAP_PART >> $LOGFILE 2>&1
    swapon $SWAP_PART >> $LOGFILE 2>&1
fi

mkdir -p $MOUNTPOINT
mount $ROOT_PART $MOUNTPOINT

if [ "$EFI_PART" != "none" ]; then
    mkdir -p $MOUNTPOINT/boot/efi
    mount $EFI_PART $MOUNTPOINT/boot/efi
fi

# ── Copy live system ───────────────────────────
dialog --backtitle "ENux Installer" --title "Installing ENux..." \
       --infobox "\n[2/7] Copying filesystem to $ROOT_PART...\n\n  This is the longest step, please be patient.\n  You can follow progress with:\n  tail -f $LOGFILE" 11 60

log "rsyncing live system to $MOUNTPOINT..."
rsync -aAX \
    --exclude=/proc \
    --exclude=/sys \
    --exclude=/dev \
    --exclude=/run \
    --exclude=/tmp \
    --exclude=/mnt \
    --exclude=/lost+found \
    --exclude=/media \
    --exclude=/run/live \
    --exclude=/run/initramfs \
    --exclude=/mnt/ENux \
    / $MOUNTPOINT >> $LOGFILE 2>&1 || bail "rsync failed. Check $LOGFILE."

mkdir -p $MOUNTPOINT/{proc,sys,dev,run,tmp,mnt,media}
log "rsync complete"

# ── fstab & hostname ───────────────────────────
dialog --backtitle "ENux Installer" --title "Installing ENux..." \
       --infobox "\n[3/7] Writing system config..." 5 55

log "Writing fstab..."
ROOT_UUID=$(blkid -s UUID -o value $ROOT_PART)
cat > $MOUNTPOINT/etc/fstab <<EOF
# ENux fstab
UUID=$ROOT_UUID  /          ext4  errors=remount-ro  0  1
EOF
if [ "$EFI_PART" != "none" ]; then
    EFI_UUID=$(blkid -s UUID -o value $EFI_PART)
    echo "UUID=$EFI_UUID   /boot/efi  vfat  umask=0077  0  1" >> $MOUNTPOINT/etc/fstab
fi
if [ "$SWAP_PART" != "none" ]; then
    SWAP_UUID=$(blkid -s UUID -o value $SWAP_PART)
    echo "UUID=$SWAP_UUID  none  swap  sw  0  0" >> $MOUNTPOINT/etc/fstab
fi

echo "$HOSTNAME" > $MOUNTPOINT/etc/hostname
cat > $MOUNTPOINT/etc/hosts <<EOF
127.0.0.1   localhost
127.0.1.1   $HOSTNAME
::1         localhost ip6-localhost ip6-loopback
ff02::1     ip6-allnodes
ff02::2     ip6-allrouters
EOF

# ── Mount virtual fs's ─────────────────────────
mount --bind /dev  $MOUNTPOINT/dev
mount --bind /proc $MOUNTPOINT/proc
mount --bind /sys  $MOUNTPOINT/sys
mount --bind /run  $MOUNTPOINT/run

# ── User setup ─────────────────────────────────
dialog --backtitle "ENux Installer" --title "Installing ENux..." \
       --infobox "\n[4/7] Setting up users..." 5 55

log "Setting up user: $USERNAME"
chroot $MOUNTPOINT userdel -r ENux >> $LOGFILE 2>&1 || true
chroot $MOUNTPOINT useradd -m -s /bin/bash -G sudo,audio,video,netdev $USERNAME >> $LOGFILE 2>&1
echo "$USERNAME:$PASSWORD" | chroot $MOUNTPOINT chpasswd >> $LOGFILE 2>&1
echo "root:$ROOT_PASSWORD"  | chroot $MOUNTPOINT chpasswd >> $LOGFILE 2>&1

# ── Update initramfs ───────────────────────────
dialog --backtitle "ENux Installer" --title "Installing ENux..." \
       --infobox "\n[5/7] Updating initramfs..." 5 55

log "Updating initramfs..."
KERNEL_VERSION=$(ls $MOUNTPOINT/boot/vmlinuz-* | tail -1 | sed 's|.*/vmlinuz-||')
chroot $MOUNTPOINT update-initramfs -u -k $KERNEL_VERSION >> $LOGFILE 2>&1

# ── Bedrock Linux ──────────────────────────────
dialog --backtitle "ENux Installer" --title "Installing ENux..." \
       --infobox "\n[6/7] Downloading and installing Bedrock Linux 0.7.31...\n\n  Please wait, downloading from GitHub." 8 60

log "Downloading Bedrock Linux 0.7.31..."
wget -q -O $MOUNTPOINT/tmp/bedrock-installer.sh "$BEDROCK_URL" >> $LOGFILE 2>&1 || \
    bail "Failed to download Bedrock. Check your internet connection."

chmod +x $MOUNTPOINT/tmp/bedrock-installer.sh
log "Running Bedrock --hijack..."
echo "y" | chroot $MOUNTPOINT /tmp/bedrock-installer.sh --hijack >> $LOGFILE 2>&1 || \
    bail "Bedrock hijack failed. Check $LOGFILE."
rm -f $MOUNTPOINT/tmp/bedrock-installer.sh
log "Bedrock installed successfully"

# ── GRUB ───────────────────────────────────────
dialog --backtitle "ENux Installer" --title "Installing ENux..." \
       --infobox "\n[7/7] Installing GRUB bootloader..." 5 55

log "Installing GRUB..."
if [ -d /sys/firmware/efi ]; then
    chroot $MOUNTPOINT apt-get install -y grub-efi-amd64 >> $LOGFILE 2>&1
    chroot $MOUNTPOINT grub-install --target=x86_64-efi \
        --efi-directory=/boot/efi \
        --bootloader-id=ENux \
        --recheck >> $LOGFILE 2>&1
else
    chroot $MOUNTPOINT apt-get install -y grub-pc >> $LOGFILE 2>&1
    chroot $MOUNTPOINT grub-install --target=i386-pc $DISK >> $LOGFILE 2>&1
fi
chroot $MOUNTPOINT update-grub >> $LOGFILE 2>&1

# ── Cleanup ────────────────────────────────────
log "Cleaning up..."
rm -f  $MOUNTPOINT/etc/live/config.conf 2>/dev/null || true
rm -rf $MOUNTPOINT/lib/live/config/*    2>/dev/null || true

# ── Unmount ────────────────────────────────────
umount -l $MOUNTPOINT/run      2>/dev/null || true
umount -l $MOUNTPOINT/dev      2>/dev/null || true
umount -l $MOUNTPOINT/proc     2>/dev/null || true
umount -l $MOUNTPOINT/sys      2>/dev/null || true
[ "$EFI_PART" != "none" ] && umount -l $MOUNTPOINT/boot/efi 2>/dev/null || true
umount -l $MOUNTPOINT          2>/dev/null || true
[ "$SWAP_PART" != "none" ] && swapoff $SWAP_PART 2>/dev/null || true

log "Installation complete!"

# ── Done ───────────────────────────────────────
dialog --backtitle "ENux Installer" \
       --title "Installation Complete!" \
       --yesno "\n✔ ENux has been successfully installed!\n\n  User:      $USERNAME\n  Hostname:  $HOSTNAME\n  Bedrock:   0.7.31 ✔\n\nReboot now?" \
       12 50 && reboot

clear
echo "Done! You can reboot manually when ready."
