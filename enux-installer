#!/bin/bash

echo "----------------------------"
echo "WELCOME TO ENUX-LW INSTALLER"
echo "----------------------------"

# --- 1. UEFI/BIOS Detection ---
if [ -d "/sys/firmware/efi" ]; then
    IS_UEFI=true
    echo "System Mode: UEFI Detected"
else
    IS_UEFI=false
    echo "System Mode: BIOS/Legacy Detected"
fi

# --- 2. Disk Selection & Partitioning ---
lsblk
echo ""
read -p "Enter the disk to partition (e.g., /dev/sda): " SELECTED_DISK

echo "Launching cfdisk..."
sleep 2
cfdisk "$SELECTED_DISK"

# --- 3. Partition Assignment ---
lsblk
echo ""
read -p "Enter your ROOT partition (e.g., /dev/sda2): " ROOT_PART

if [ "$IS_UEFI" = true ]; then
    read -p "Enter your EFI partition (e.g., /dev/sda1): " EFI_PART
fi

read -p "Did you create a SWAP partition? (y/n): " HAS_SWAP
if [[ "$HAS_SWAP" =~ ^[Yy]$ ]]; then
    read -p "Enter your SWAP partition (e.g., /dev/sda3): " SWAP_PART
fi

# --- 4. Formatting & Mounting ---
echo "Formatting and mounting..."
mkfs.ext4 -F "$ROOT_PART"
mount "$ROOT_PART" /mnt

if [ "$IS_UEFI" = true ]; then
    mkfs.fat -F 32 "$EFI_PART"
    mkdir -p /mnt/boot/efi
    mount "$EFI_PART" /mnt/boot/efi
fi

if [[ -n "$SWAP_PART" ]]; then
    mkswap "$SWAP_PART"
    swapon "$SWAP_PART"
fi

# --- 5. Copying the Root Filesystem ---
echo "Copying system files to /mnt (Excluding virtual FS)..."
# Simplified exclude syntax to prevent EOF errors
rsync -aAXv \
    --exclude=/dev/* \
    --exclude=/proc/* \
    --exclude=/sys/* \
    --exclude=/tmp/* \
    --exclude=/run/* \
    --exclude=/mnt/* \
    --exclude=/media/* \
    --exclude=/lost+found \
    / /mnt

# --- 6. Generating FSTAB ---
echo "Generating fstab..."
echo "$ROOT_PART  /  ext4  errors=remount-ro  0  1" > /mnt/etc/fstab
if [ "$IS_UEFI" = true ]; then
    echo "$EFI_PART  /boot/efi  vfat  umask=0077  0  2" >> /mnt/etc/fstab
fi
if [[ -n "$SWAP_PART" ]]; then
    echo "$SWAP_PART  none  swap  sw  0  0" >> /mnt/etc/fstab
fi

# --- 7. The Bedrock Hijack Preparation ---
echo "Downloading Bedrock Linux installer..."
wget https://github.com/bedrocklinux/bedrocklinux-userland/releases/download/0.7.31beta3/bedrock-linux-0.7.31beta3-x86_64.sh -O /mnt/bedrock-install.sh
chmod +x /mnt/bedrock-install.sh

# --- 8. Chroot: GRUB & Hijack ---
echo "Entering chroot to finalize..."

# Bind mount API filesystems
for i in dev dev/pts proc sys run; do mount --bind /$i /mnt/$i; done

# Using a more stable chroot execution method
chroot /mnt /bin/bash <<CHROOT_BLOCK
apt-get update

if [ "$IS_UEFI" = true ]; then
    echo "Installing UEFI GRUB..."
    DEBIAN_FRONTEND=noninteractive apt-get install -y grub-efi-amd64 efibootmgr
    grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=BEDROCK
else
    echo "Installing BIOS GRUB..."
    DEBIAN_FRONTEND=noninteractive apt-get install -y grub-pc
    grub-install --target=i386-pc "$SELECTED_DISK"
fi

grub-mkconfig -o /boot/grub/grub.cfg

echo "Starting Bedrock Hijack..."
# Use 'sh' directly inside the chroot
yes "Not reversible!" | bash /bedrock-install.sh --hijack
CHROOT_BLOCK

echo "DONE! Unmounting..."
umount -l /mnt/dev/pts
umount -l /mnt/dev
umount -l /mnt/proc
umount -l /mnt/sys
umount -l /mnt/run
umount -R /mnt

echo "Installation complete. Reboot for Finalizer"
