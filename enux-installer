#!/bin/bash
set -e

clear
echo "================================="
echo "        ENux CLI Installer       "
echo "================================="
echo

read -p "Press Enter to start installation..."

echo
lsblk
echo
read -p "Enter the drive to install ENux on (example: /dev/sda): " DRIVE

echo
echo "Opening cfdisk..."
sleep 2
cfdisk $DRIVE

while true; do
    read -p "Return to cfdisk? (y/n): " CF
    case $CF in
        y|Y ) cfdisk $DRIVE ;;
        n|N ) break ;;
        * ) echo "Please answer y or n." ;;
    esac
done

echo
lsblk
echo

read -p "Enter ROOT partition (example: /dev/sda2): " ROOT

read -p "Create swap? (y/n): " SWAPCHOICE
if [[ "$SWAPCHOICE" =~ ^[Yy]$ ]]; then
    read -p "Enter SWAP partition (example: /dev/sda3): " SWAP
fi

echo
read -p "WARNING: This will erase $ROOT. Continue? (yes/no): " CONF
[[ "$CONF" != "yes" ]] && exit 1

echo
echo "Formatting root partition..."
mkfs.ext4 $ROOT

if [[ "$SWAPCHOICE" =~ ^[Yy]$ ]]; then
    echo "Formatting swap..."
    mkswap $SWAP
    swapon $SWAP
fi

echo
echo "Mounting root partition..."
mkdir -p /mnt/ENux
mount $ROOT /mnt/ENux

echo
echo "Bootstrapping ENux..."
enuxbootstrap /mnt/ENux

echo
echo "Installing base packages..."
chroot /mnt/ENux apt update
chroot /mnt/ENux apt install -y \
network-manager \
sudo \
wget \
curl \
xfce4 \
xfce4-goodies \
lightdm \
lightdm-gtk-greeter \
grub-pc \
grub-efi-amd64 \
initramfs-tools

echo
echo "Setting hostname..."
read -p "Enter hostname: " HOSTNAME
echo "$HOSTNAME" > /mnt/ENux/etc/hostname

echo "127.0.0.1 localhost" >> /mnt/ENux/etc/hosts
echo "127.0.1.1 $HOSTNAME" >> /mnt/ENux/etc/hosts

echo
echo "Creating user..."
read -p "Enter username: " USERNAME

chroot /mnt/ENux useradd -m -G wheel,audio,video,netdev -s /bin/bash $USERNAME

echo "Set password for $USERNAME"
chroot /mnt/ENux passwd $USERNAME

echo "Set root password"
chroot /mnt/ENux passwd

echo
echo "Detecting firmware..."

if [ -d /sys/firmware/efi ]; then
    echo "EFI system detected"

    read -p "Enter EFI partition (example: /dev/sda1): " EFI

    mkfs.fat -F32 $EFI
    mkdir -p /mnt/ENux/boot/efi
    mount $EFI /mnt/ENux/boot/efi

    chroot /mnt/ENux grub-install \
        --target=x86_64-efi \
        --efi-directory=/boot/efi \
        --bootloader-id=ENux

else
    echo "Legacy BIOS detected"

    chroot /mnt/ENux grub-install $DRIVE
fi

echo
echo "Generating GRUB config..."
chroot /mnt/ENux grub-mkconfig -o /boot/grub/grub.cfg

read -p "Generate initramfs? (y/n): " INIT
if [[ "$INIT" =~ ^[Yy]$ ]]; then
    chroot /mnt/ENux update-initramfs -c -k all
fi

echo
echo "Running ENux Bedrock setup..."
chroot /mnt/ENux bash /usr/bin/enux-chrooted

echo
echo "Enabling services..."
chroot /mnt/ENux systemctl enable NetworkManager
chroot /mnt/ENux systemctl enable lightdm

echo
echo "Syncing disks..."
sync

echo
echo "Unmounting system..."
umount -R /mnt/ENux

echo
echo "================================="
echo "       ENux installation done    "
echo "================================="

read -p "Reboot now? (y/n): " RB
if [[ "$RB" =~ ^[Yy]$ ]]; then
    reboot
else
    echo "Installation finished. Reboot manually when ready."
fi
