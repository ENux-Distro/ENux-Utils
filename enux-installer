#!/bin/bash
set -e

[ "$EUID" -ne 0 ] && echo "Run as root." && exit 1

TITLE="ENux Installer"

pause(){
    whiptail --title "$TITLE" --msgbox "$1" 10 60
}

INPUT(){
    whiptail --title "$TITLE" --inputbox "$1" 10 60 "$2" 3>&1 1>&2 2>&3
}

YESNO(){
    whiptail --title "$TITLE" --yesno "$1" 10 60
}

MENU(){
    whiptail --title "$TITLE" --menu "$1" 15 60 6 "$@" 3>&1 1>&2 2>&3
}

pause "Welcome to the ENux Installer"

DRIVE=$(INPUT "Enter the drive to install ENux on (example: /dev/sda)")

pause "Opening partition editor"

cfdisk $DRIVE

while YESNO "Return to cfdisk?"; do
    cfdisk $DRIVE
done

ROOT=$(INPUT "Enter ROOT partition (example: /dev/sda2)")

if YESNO "Create swap?"; then
    SWAP=$(INPUT "Enter SWAP partition (example: /dev/sda3)")
    USE_SWAP=true
else
    USE_SWAP=false
fi

if ! YESNO "WARNING: This will erase $ROOT. Continue?"; then
    exit 1
fi

pause "Formatting root partition..."

mkfs.ext4 $ROOT

if $USE_SWAP; then
    mkswap $SWAP
    swapon $SWAP
fi

pause "Mounting system..."

mkdir -p /mnt/ENux
mount $ROOT /mnt/ENux

apt install -y arch-install-scripts

pause "Bootstrapping ENux..."

enuxbootstrap /mnt/ENux

pause "Installing base packages..."

enux-chroot /mnt/ENux apt update
enux-chroot /mnt/ENux apt install -y \
network-manager \
sudo \
wget \
curl \
xfce4 \
xfce4-goodies \
lightdm \
lightdm-gtk-greeter \
initramfs-tools

cp /etc/os-release /mnt/ENux/etc/os-release
cp /usr/bin/enux-firstboot /mnt/ENux/usr/bin/enux-firstboot

HOSTNAME=$(INPUT "Enter hostname")

echo "$HOSTNAME" > /mnt/ENux/etc/hostname
echo "127.0.0.1 localhost" >> /mnt/ENux/etc/hosts
echo "127.0.1.1 $HOSTNAME" >> /mnt/ENux/etc/hosts

USERNAME=$(INPUT "Enter username")

enux-chroot /mnt/ENux useradd -m -G sudo,audio,video,netdev -s /bin/bash $USERNAME

pause "Set password for $USERNAME"
enux-chroot /mnt/ENux passwd $USERNAME

mkdir -p /mnt/ENux/home/"$USERNAME"/.config/autostart || true
cp /usr/share/enux/enux-firstboot.desktop \
/mnt/ENux/home/"$USERNAME"/.config/autostart/enux-firstboot.desktop || true

enux-chroot /mnt/ENux chown -R "$USERNAME:$USERNAME" \
/home/"$USERNAME"/.config || true

pause "Set root password"
enux-chroot /mnt/ENux passwd

pause "Detecting firmware..."

if [ -d /sys/firmware/efi ]; then

    EFI=$(INPUT "Enter EFI partition (example: /dev/sda1)")

    mkfs.fat -F32 $EFI || true
    mkdir -p /mnt/ENux/boot/efi
    mount $EFI /mnt/ENux/boot/efi

    enux-chroot /mnt/ENux apt install grub-efi-amd64 grub-common -y

    enux-chroot /mnt/ENux grub-install \
        --target=x86_64-efi \
        --efi-directory=/boot/efi \
        --bootloader-id=ENux

else

    enux-chroot /mnt/ENux apt install grub-pc grub-common -y
    enux-chroot /mnt/ENux grub-install $DRIVE

fi

pause "Generating fstab..."

genfstab -U /mnt/ENux > /mnt/ENux/etc/fstab

pause "Updating initramfs..."

enux-chroot /mnt/ENux update-initramfs -c -k all

pause "Generating GRUB config..."

enux-chroot /mnt/ENux grub-mkconfig -o /boot/grub/grub.cfg

pause "Running ENux Bedrock setup..."

enux-chroot /mnt/ENux wget \
https://raw.githubusercontent.com/ENux-Distro/mirrors/refs/heads/main/enux-chroot \
-O /usr/local/bin/enux-chrooted

enux-chroot /mnt/ENux bash /usr/local/bin/enux-chrooted

pause "Enabling services..."

enux-chroot /mnt/ENux systemctl enable NetworkManager
enux-chroot /mnt/ENux systemctl enable lightdm

enux-chroot /mnt/ENux rm -rf /usr/share/images/desktop-base
enux-chroot /mnt/ENux rm -rf /usr/local/bin/enux-chrooted

pause "Syncing disks..."

sync

pause "Unmounting system..."

umount -R /mnt/ENux

if YESNO "Installation finished. Reboot now?"; then
    reboot
fi
