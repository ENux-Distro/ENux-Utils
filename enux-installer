#!/bin/bash

# --- ENux High-Contrast Theme ---
export NEWT_COLORS='
  root=,black
  window=white,black
  border=white,black
  shadow=white,black
  button=black,white
  actbutton=white,black
  compactbutton=black,white
  title=white,black
  roottext=white,black
  textbox=white,black
  acttextbox=black,white
  entry=white,black
  disentry=gray,black
  checkbox=white,black
  actcheckbox=black,white
  listbox=white,black
  actlistbox=black,white
  actselitem=black,white
'

exit_script() {
    clear
    echo "ENux installation aborted."
    exit 1
}

WT_HEIGHT=18
WT_WIDTH=70

# --- 1. System Identity & User ---
HOSTNAME=$(whiptail --title " HOSTNAME " --inputbox "Enter System Hostname:" $WT_HEIGHT $WT_WIDTH "ENux-Station" 3>&1 1>&2 2>&3) || exit_script
USERNAME=$(whiptail --title " USER ACCOUNT " --inputbox "Enter Username:" $WT_HEIGHT $WT_WIDTH "emir" 3>&1 1>&2 2>&3) || exit_script
USER_PW=$(whiptail --title " USER PASSWORD " --passwordbox "Password for $USERNAME:" $WT_HEIGHT $WT_WIDTH 3>&1 1>&2 2>&3) || exit_script
ROOT_PW=$(whiptail --title " ROOT PASSWORD " --passwordbox "Password for Root:" $WT_HEIGHT $WT_WIDTH 3>&1 1>&2 2>&3) || exit_script

# --- 2. Disk & Partitioning ---
DISK_LIST=$(lsblk -dno NAME,SIZE,MODEL | awk '{print "/dev/"$1, "["$2, $3$4$5"]"}' | tr '\n' ' ')
TARGET_DISK=$(whiptail --title " DISK SELECTION " --menu "Choose target drive:" $WT_HEIGHT $WT_WIDTH 6 $DISK_LIST 3>&1 1>&2 2>&3) || exit_script

# Partitioning
cfdisk "$TARGET_DISK"

ROOT_PART=$(whiptail --title " ROOT PARTITION " --inputbox "Enter ROOT partition (e.g., /dev/sda2):" $WT_HEIGHT $WT_WIDTH 3>&1 1>&2 2>&3) || exit_script
BOOT_PART=$(whiptail --title " EFI PARTITION " --inputbox "Enter EFI partition (leave blank if none):" $WT_HEIGHT $WT_WIDTH 3>&1 1>&2 2>&3) || exit_script

# --- 3. THE VERIFICATION SCREEN ---
CONFIRM_MSG="ENux Deployment Summary:
---------------------------
Hostname:  $HOSTNAME
User:      $USERNAME
Root Part: $ROOT_PART
EFI Part:  ${BOOT_PART:-None}

WARNING: This will format selected partitions and install Bedrock Linux. Proceed?"

if ! whiptail --title " FINAL VERIFICATION " --yesno "$CONFIRM_MSG" $WT_HEIGHT $WT_WIDTH; then
    exit_script
fi

# --- 4. DEPLOYMENT ---
(
    echo 10; mkfs.ext4 -F "$ROOT_PART" >/dev/null 2>&1
    mount "$ROOT_PART" /mnt

    if [ -n "$BOOT_PART" ]; then
        mkfs.vfat -F32 "$BOOT_PART" >/dev/null 2>&1
        mkdir -p /mnt/boot/efi
        mount "$BOOT_PART" /mnt/boot/efi
    fi

    echo 30; # FSTAB
    ROOT_UUID=$(blkid -s UUID -o value "$ROOT_PART")
    echo "UUID=$ROOT_UUID / ext4 errors=remount-ro 0 1" > /mnt/etc/fstab
    if [ -n "$BOOT_PART" ]; then
        BOOT_UUID=$(blkid -s UUID -o value "$BOOT_PART")
        echo "UUID=$BOOT_UUID /boot/efi vfat defaults 0 2" >> /mnt/etc/fstab
    fi

    echo 50; # Copying Files
    rsync -aAX --exclude={"/dev/*","/proc/*","/sys/*","/tmp/*","/run/*","/mnt/*","/media/*","/lost+found"} / /mnt

    echo 70; # Chroot & Bedrock
    for i in /dev /dev/pts /proc /sys /run; do mount -B $i /mnt$i; done
    
    cat <<EOF | chroot /mnt
    echo "$HOSTNAME" > /etc/hostname
    echo "root:$ROOT_PW" | chpasswd
    useradd -m -s /bin/bash "$USERNAME"
    echo "$USERNAME:$USER_PW" | chpasswd
    usermod -aG sudo "$USERNAME"
    update-initramfs -u
    wget https://raw.githubusercontent.com/bedrocklinux/bedrocklinux-userland/0.7/installer/bedrock-linux-0.7.29-x86_64.sh -O /tmp/bedrock.sh
    sh /tmp/bedrock.sh --hijack
    update-grub
EOF
    echo 100
) | whiptail --title " DEPLOYING ENux " --gauge "Bootstrap in progress..." $WT_HEIGHT $WT_WIDTH 0

whiptail --title " DEPLOYMENT COMPLETE " --msgbox "ENux is ready. Reboot to initialize Bedrock." $WT_HEIGHT $WT_WIDTH
umount -l /mnt
clear
