#!/bin/bash

set -e

DIALOG=dialog
BACKTITLE="ENux GNU/Linux 5.1.1 Installer"
MOUNTPOINT=/mnt/ENux
LOGFILE=/tmp/enux-install.log
BEDROCK_URL="https://github.com/bedrocklinux/bedrocklinux-userland/releases/download/0.7.31/bedrock-linux-0.7.31-x86_64.sh"

log() { echo "[$(date '+%H:%M:%S')] $*" >> $LOGFILE; }

bail() {
$DIALOG --backtitle "$BACKTITLE" \
    --title "Error" \
    --msgbox "\n$1\n\nCheck $LOGFILE for details." 10 55
exit 1
}

run() { log "RUN: $*"; "$@" >> $LOGFILE 2>&1 || bail "Command failed: $*"; }

if [ "$EUID" -ne 0 ]; then
echo "ENux Installer must be run as root."
exit 1
fi

> $LOGFILE
log "ENux Installer started"

$DIALOG --backtitle "$BACKTITLE" \
--title "ENux Installer" \
--msgbox "\nWelcome to the ENux GNU/Linux 5.1.1 Installer.\n\nYou will be asked to select your partitions.\nThe system will then be installed automatically.\n\n⚠ Make sure you have an internet connection.\n  Bedrock Linux will be downloaded during install." \
13 58

PARTS=()
while IFS= read -r line; do
PNAME=$(echo "$line" | awk '{print $1}')
PSIZE=$(echo "$line" | awk '{print $2}')
PFS=$(echo "$line"   | awk '{print $3}')
PARTS+=("/dev/$PNAME" "$PSIZE ${PFS:-unknown}")
done < <(lsblk -o NAME,SIZE,FSTYPE --noheadings | grep -E "^[├─└ ]*[a-z].*[0-9]" | sed 's/^[^a-z]*//')

ROOT_PART=$($DIALOG --backtitle "$BACKTITLE" \
            --title "Root Partition" \
            --menu "\nSelect partition for / (will be formatted as ext4):" \
            20 60 8 "${PARTS[@]}" \
            3>&1 1>&2 2>&3) || bail "Cancelled."

EFI_PART=$($DIALOG --backtitle "$BACKTITLE" \
           --title "EFI Partition" \
           --menu "\nSelect your EFI partition (FAT32, ~512MB):" \
           20 60 8 "${PARTS[@]}" \
           3>&1 1>&2 2>&3) || bail "Cancelled."

SWAP_PART=$($DIALOG --backtitle "$BACKTITLE" \
            --title "Swap Partition (Optional)" \
            --menu "\nSelect swap partition or skip:" \
            20 60 9 \
            "none" "Skip - no swap" \
            "${PARTS[@]}" \
            3>&1 1>&2 2>&3) || SWAP_PART="none"

# Confirm
INSTALL_DISK=$(lsblk -no PKNAME $ROOT_PART 2>/dev/null | head -1)
INSTALL_DISK="/dev/$INSTALL_DISK"

$DIALOG --backtitle "$BACKTITLE" \
--title "Confirm" \
--yesno "\nReady to install:\n\n  Root:  $ROOT_PART  (will be formatted)\n  EFI:   $EFI_PART\n  Swap:  $SWAP_PART\n  Disk:  $INSTALL_DISK\n\nProceed?" \
13 50 || bail "Cancelled."

(
echo "2"
log "Formatting partitions..."
run mkfs.ext4 -F $ROOT_PART
[ "$SWAP_PART" != "none" ] && run mkswap $SWAP_PART
echo "5"

log "Mounting partitions..."
mkdir -p $MOUNTPOINT
run mount $ROOT_PART $MOUNTPOINT
mkdir -p $MOUNTPOINT/boot/efi
run mount $EFI_PART $MOUNTPOINT/boot/efi
[ "$SWAP_PART" != "none" ] && swapon $SWAP_PART >> $LOGFILE 2>&1 || true
echo "8"

log "Copying root filesystem (excluding virtual filesystems)..."
run rsync -aAX --progress \
--exclude=/proc \
--exclude=/sys \
--exclude=/dev \
--exclude=/run \
--exclude=/tmp \
--exclude=/mnt \
--exclude=/lost+found \
/ $MOUNTPOINT/
echo "45"

log "Creating essential directories..."
mkdir -p $MOUNTPOINT/{proc,sys,dev,run,tmp,mnt}
chmod 1777 $MOUNTPOINT/tmp
echo "48"

log "Generating fstab..."
ROOT_UUID=$(blkid -s UUID -o value $ROOT_PART)
EFI_UUID=$(blkid -s UUID -o value $EFI_PART)
cat > $MOUNTPOINT/etc/fstab <<EOF
# ENux fstab
UUID=$ROOT_UUID  /          ext4  errors=remount-ro  0  1
UUID=$EFI_UUID   /boot/efi  vfat  umask=0077         0  1
EOF
[ "$SWAP_PART" != "none" ] && \
echo "UUID=$(blkid -s UUID -o value $SWAP_PART)  none  swap  sw  0  0" >> $MOUNTPOINT/etc/fstab
echo "50"

log "Mounting virtual filesystems..."
mount --bind /dev  $MOUNTPOINT/dev
mount --bind /proc $MOUNTPOINT/proc
mount --bind /sys  $MOUNTPOINT/sys
mount --bind /run  $MOUNTPOINT/run

log "Updating initramfs..."
run chroot $MOUNTPOINT update-initramfs -u -k all
echo "60"

log "Downloading Bedrock Linux 0.7.31..."
wget -q -O $MOUNTPOINT/tmp/bedrock-installer.sh "$BEDROCK_URL" >> $LOGFILE 2>&1 || \
bail "Failed to download Bedrock. Check your internet connection."
chmod +x $MOUNTPOINT/tmp/bedrock-installer.sh
echo "68"

log "Hijacking with Bedrock Linux..."
echo "y" | chroot $MOUNTPOINT /tmp/bedrock-installer.sh --hijack >> $LOGFILE 2>&1 || \
bail "Bedrock hijack failed."
rm -f $MOUNTPOINT/tmp/bedrock-installer.sh
echo "78"

log "Installing GRUB..."
run chroot $MOUNTPOINT grub-install --target=x86_64-efi \
--efi-directory=/boot/efi \
--bootloader-id=ENux \
--recheck
run chroot $MOUNTPOINT grub-install --target=i386-pc $INSTALL_DISK
run chroot $MOUNTPOINT update-grub
echo "92"

log "Cleaning up..."
umount -l $MOUNTPOINT/run  2>/dev/null || true
umount -l $MOUNTPOINT/dev  2>/dev/null || true
umount -l $MOUNTPOINT/proc 2>/dev/null || true
umount -l $MOUNTPOINT/sys  2>/dev/null || true
umount -l $MOUNTPOINT/boot/efi 2>/dev/null || true
umount -l $MOUNTPOINT      2>/dev/null || true
[ "$SWAP_PART" != "none" ] && swapoff $SWAP_PART 2>/dev/null || true

echo "100"
) | $DIALOG --backtitle "$BACKTITLE" \
    --title "Installing ENux..." \
    --gauge "\nInstalling ENux GNU/Linux 5.1.1...\n\nThis may take a few minutes." \
    10 55 0


$DIALOG --backtitle "$BACKTITLE" \
--title "Installation Complete!" \
--yesno "\n✔ ENux GNU/Linux 5.1.1 installed successfully!\n\nWould you like to reboot now?" \
9 48

[ $? -eq 0 ] && reboot || clear
